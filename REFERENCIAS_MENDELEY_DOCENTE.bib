@ARTICLE{Zhao2025,
	author = {Zhao, Hongyang and Zhang, Ke and Li, Xingdong and Jin, Jing},
	title = {MYIGWO: A grey wolf optimizer with dual mutation and chaotic adaptive neighborhood for engineering problems and path planning},
	year = {2025},
